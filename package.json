{
  "name": "stockflow-mobile-app",
  "version": "1.0.0",
  "main": "expo/AppEntry.js",
  "scripts": {
    "start": "EXPO_UNSTABLE_HEADLESS=1 expo start",
    "start:clear": "EXPO_UNSTABLE_HEADLESS=1 expo start -c",
    "start:go": "EXPO_UNSTABLE_HEADLESS=1 expo start",
    "android": "EXPO_UNSTABLE_HEADLESS=1 expo start --android",
    "ios": "EXPO_UNSTABLE_HEADLESS=1 expo start --ios",
    "web": "EXPO_UNSTABLE_HEADLESS=1 expo start --web",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "expo": "^55.0.24",
    "expo-status-bar": "~55.0.6",
    "nativewind": "^4.1.23",
    "react": "19.2.0",
    "react-native": "0.83.6",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-worklets": "0.7.4"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/react": "~19.2.0",
    "babel-preset-expo": "~55.0.8",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.9.2"
  },
  "private": true
}
